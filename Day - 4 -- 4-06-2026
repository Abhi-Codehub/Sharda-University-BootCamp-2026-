Program -- 1
Print 1 to 10 using Recursion 
public class Main {
        
    public static void printNumber(int n) {
        // base condition 
        if(n > 10){
            return;
        }
        // logic 
        System.out.print(n + " ");
        printNumber(n+1);
    }    
	public static void main(String[] args) {
	    printNumber(1);
	}
}
Program -- 2
Print 10 to 1 using Recursion 

public class Main {
        
    public static void printNumber(int n) {
        // base condition 
        if(n < 1){
            return;
        }
        // logic 
        System.out.print(n + " ");
        printNumber(n - 1);
    }    
	public static void main(String[] args) {
	    printNumber(10);
	}
}




